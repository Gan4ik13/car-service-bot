# Telegram Bot Token (получить у @BotFather)
BOT_TOKEN=ваш_токен_бота

# ID администраторов (через запятую, узнать у @userinfobot)
ADMIN_IDS=123456789,987654321

# PostgreSQL (Supabase — https://supabase.com — бесплатно)
# Формат: postgresql+asyncpg://user:password@host:5432/dbname
DATABASE_URL=postgresql+asyncpg://postgres:пароль@aws-0-region.supabase.co:5432/postgres
